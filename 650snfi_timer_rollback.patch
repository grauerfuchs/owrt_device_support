 /* Timer helpers */
 typedef uint64_t mtk_snand_time_t;
 
+static inline uint64_t get_timer(uint64_t base)
+{
+	uint64_t n;
+	uint64_t tmc = read_cntpct_el0();
+	uint32_t freq = read_cntfrq_el0();
+	
+	if ((ULLONG_MAX - freq + 1) / 1000000ULL <= tmc)
+		n = ULLONG_MAX - freq + 1;
+	else
+		n = tmc * 1000000ULL;
+
+	tmc = div_round_up(n, freq);
+
+	if (tmc >= base)
+		return tmc - base;
+
+	return ~(base - tmc);
+}
+
 static inline mtk_snand_time_t timer_get_ticks(void)
